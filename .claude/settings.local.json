{
  "permissions": {
    "allow": [
      "Bash:*",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Agent",
      "TaskList",
      "TaskGet",
      "TaskCreate",
      "TaskUpdate",
      "Bash(git add .claude/settings.local.json && git commit -m \"code & fix\" && git push 2>&1)"
    ],
    "deny": [
      "Bash:sudo:*",
      "Bash:rm:--rf:/",
      "Bash:rm:--rf:/*",
      "Bash:curl:--pipe:sh",
      "Bash:wget:--pipe:sh",
      "Bash:mkfs:*",
      "Bash:dd:*",
      "Bash:chmod:777",
      "Bash:chmod:000"
    ]
  }
}
